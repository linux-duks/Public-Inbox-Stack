[publicinbox]
        grokmanifest = all
        wwwListing = all
        css = /static/theme.css title=216dark

[extindex "all"]
        topdir = /data/all
        url = https://lore.lore.your.instance.tld/


[publicinbox "your-lore"]
        address = address@lists.ime.usp.br
        url = https://lore.lore.your.instance.tld/kernel.ime/

        inboxdir = /data/your-lore/
        watch = "imaps://user@email:pass@imap:993/INBOX"


[publicinboxwatch]
		; optional, enable use of spamc(1) for checking:
		spamcheck = spamc

		; optional, emails marked as read which appear
		; here will be trained as spam and deleted from
		; the inboxdirs of any public-inboxes which are
		; configured for watch.
		; This is global for all publicinbox.* sections
		;watchspam = maildir:/mail/Junk

